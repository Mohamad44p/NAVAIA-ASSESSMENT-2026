# ─────────────────────────────────────────────────────────────────
# SDK environment — read by the Python scripts (config.py).
# Copy to `.env.local` and fill in your values:   cp .env.local.example .env.local
# This file is git-ignored; it never leaves your machine.
# ─────────────────────────────────────────────────────────────────

# Account registered on your LOCAL backend (Phase 2 — 01_register.py)
NAVAIA_NAME=Your Name
NAVAIA_EMAIL=you@example.com
NAVAIA_PASSWORD=choose-a-strong-password

# Local backend API key — written automatically by 01_register.py.
# (Lives in .forge_state.json; uncomment here only to override.)
# NAVAIA_LOCAL_API_KEY=nf_...

# Cloud key from https://fareegi.navaia.sa (Settings > Manage API keys) — Phase 5
NAVAIA_CLOUD_API_KEY=nf_cloud_...

# Optional overrides
# NAVAIA_LOCAL_URL=http://localhost:8001
# NAVAIA_MODEL=anthropic/claude-sonnet-4
# NAVAIA_TOPIC=How AI customer-support agents are changing the game for small businesses
