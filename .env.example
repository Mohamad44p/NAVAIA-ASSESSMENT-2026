# ─────────────────────────────────────────────────────────────────
# Backend environment — read by docker-compose.dist.yml (Phase 1).
# Copy to `.env` and fill in your values:   cp .env.example .env
#
# Generate SECRET_KEY / WEAVIATE_API_KEY with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-random-64-char-hex
POSTGRES_USER=navaia_forge
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=navaia_forge
API_PORT=8001
OPENROUTER_API_KEY=sk-or-v1-your-key-here
WEAVIATE_API_KEY=replace-with-a-random-64-char-hex
ALLOWED_ORIGINS=http://localhost:3030,http://localhost:3000
