# ─────────────────────────────────────────────────────────────────
# Backend environment — read by docker-compose.dist.yml (Phase 1).
# Copy to `.env` and fill in your values:   cp .env.example .env
#
# Generate the random secrets (SECRET_KEY, WEAVIATE_API_KEY) with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Generate the Fernet key (GITHUB_TOKEN_ENC_KEY) with:
#   python -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# ─────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-random-64-char-hex
POSTGRES_USER=navaia_forge
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=navaia_forge
API_PORT=8001
OPENROUTER_API_KEY=sk-or-v1-your-key-here
WEAVIATE_API_KEY=replace-with-a-random-64-char-hex

# The backend runs in production mode (DEBUG=false) and refuses to start unless
# ALLOWED_ORIGINS contains at least one non-localhost origin. Keep your localhost
# dev origins and add the cloud frontend so the guard passes.
ALLOWED_ORIGINS=http://localhost:3030,http://localhost:3000,https://fareegi.navaia.sa

# Fernet key for encrypting stored integration tokens — required at startup.
GITHUB_TOKEN_ENC_KEY=replace-with-a-fernet-key
